\begin{theindex}
  \def\seename{见}
  \def\alsoname{又见}
  \providecommand*\indexgroup[1]{%
    \indexspace
    \item \textbf{#1}\nopagebreak}
  %
  \indexgroup{符号}
  %

  \item 10 apples, 1
  \item 9 apples, 2

  \indexspace

  %
  \indexgroup{数字}
  %

  \item 0, 0
  \item 02, 2
  \item 2, 2
  \item 9, 9
  \item 15567, 15567
  \item Ⅰ, 1
  \item Ⅳ, 4
  \item ①, 1
  \item ⑧, 8
  \item ⑴, 1
  \item ⑾, 11

  \indexspace

  %
  \indexgroup{F}
  %

  \item foo, 999

  \indexspace

  %
  \indexgroup{H}
  %

  \item 汉字, 999

  \indexspace

  %
  \indexgroup{L}
  %

  \item 〇, i, xii

\end{theindex}
